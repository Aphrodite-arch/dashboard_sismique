# =============================================================================
# .gitignore — Fichiers à NE PAS envoyer sur GitHub
# =============================================================================
# Ce fichier dit à Git quels fichiers ignorer quand tu pousses sur GitHub.
# TRÈS IMPORTANT : il protège tes données confidentielles.

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --- Streamlit ---
.streamlit/secrets.toml

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Éditeurs ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Logs ---
*.log
